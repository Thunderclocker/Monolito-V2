{
  "compilerOptions": {
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "module": "preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    },
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
